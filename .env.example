# === Hugging Face ===
HF_TOKEN=hf_your_write_token_here
HF_USERNAME=your_hf_username

# === API Keys (for data generation only) ===
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# === Model Config ===
BRAIN_BASE_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
CODER_BASE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# === HuggingFace Repo Names (for push) ===
BRAIN_HF_REPO=your_hf_username/vidgen-brain-7b
CODER_HF_REPO=your_hf_username/vidgen-coder-7b

# === GPU Override (optional: "dgx" or "local", auto-detected if empty) ===
GPU_PROFILE=
